<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/edit_profile_title"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- Profil Resmi Kısmı -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivEditProfilePic"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:padding="2dp"
                app:strokeWidth="2dp"
                app:strokeColor="#4FC3F7"
                app:shapeAppearanceOverlay="@style/CircleImage"
                android:src="@android:drawable/ic_menu_gallery"
                android:contentDescription="Profil Resmi"
                android:scaleType="centerCrop" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <Button
                    android:id="@+id/btnChangePic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Değiştir"
                    android:textSize="12sp"
                    android:textAllCaps="false"
                    android:backgroundTint="#4FC3F7"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btnRemovePic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kaldır"
                    android:textSize="12sp"
                    android:textAllCaps="false"
                    android:backgroundTint="#FF6B6B"
                    android:textColor="#FFFFFF" />
            </LinearLayout>
        </LinearLayout>

        <!-- Okul Adı -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/school_name_label"
            android:textColor="#AAAAAA"
            android:layout_marginBottom="8dp" />
        <EditText
            android:id="@+id/etEditSchool"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/input_border"
            android:textColor="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:hint="@string/school_name_hint"
            android:textColorHint="#555555"
            android:inputType="text"
            android:importantForAutofill="no" />

        <!-- Bölüm -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/department_label"
            android:textColor="#AAAAAA"
            android:layout_marginBottom="8dp" />
        <EditText
            android:id="@+id/etEditDepartment"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/input_border"
            android:textColor="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:hint="@string/department_hint"
            android:textColorHint="#555555"
            android:inputType="text"
            android:importantForAutofill="no" />

        <!-- Kulüp (Sorumlular için) -->
        <LinearLayout
            android:id="@+id/layoutClubEdit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/club_name_label"
                android:textColor="#AAAAAA"
                android:layout_marginBottom="8dp" />
            <EditText
                android:id="@+id/etEditClubName"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/input_border"
                android:textColor="#FFFFFF"
                android:padding="12dp"
                android:layout_marginBottom="16dp"
                android:hint="@string/club_name_hint"
                android:textColorHint="#555555"
                android:inputType="text"
                android:importantForAutofill="no" />
        </LinearLayout>

        <!-- Biyografi -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/bio_label"
            android:textColor="#AAAAAA"
            android:layout_marginBottom="8dp" />
        <EditText
            android:id="@+id/etEditBio"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="@drawable/input_border"
            android:textColor="#FFFFFF"
            android:padding="12dp"
            android:gravity="top"
            android:layout_marginBottom="24dp"
            android:hint="@string/bio_hint"
            android:textColorHint="#555555"
            android:inputType="textMultiLine"
            android:importantForAutofill="no" />

        <Button
            android:id="@+id/btnSaveProfile"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="@string/save_profile"
            android:backgroundTint="#4FC3F7"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="32dp"
            android:textAllCaps="false" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#3A3A4E"
            android:layout_marginBottom="24dp" />

        <!-- Şifre Değiştirme -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/change_password_title"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/etNewPassword"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/input_border"
            android:textColor="#FFFFFF"
            android:padding="12dp"
            android:inputType="textPassword"
            android:layout_marginBottom="12dp"
            android:hint="@string/new_password_hint"
            android:textColorHint="#555555"
            android:importantForAutofill="no" />

        <Button
            android:id="@+id/btnUpdatePassword"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="@string/update_password_btn"
            android:backgroundTint="#FF6B6B"
            android:textColor="#FFFFFF"
            android:textAllCaps="false" />

    </LinearLayout>
</ScrollView>
